{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    // Mirror metro.config.js: the linked package resolves its peers from the
    // repo root's node_modules, which gives TypeScript two copies of the
    // reanimated / react-native types. Pin type resolution to the example's
    // copies so both sides share one type identity.
    "paths": {
      "react": ["./node_modules/@types/react"],
      "react-native": ["./node_modules/react-native"],
      "react-native-reanimated": ["./node_modules/react-native-reanimated"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
